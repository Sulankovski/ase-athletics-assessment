# --- Required ---
# PostgreSQL connection string (used by node-pg Pool)
# Local Docker (see repo root docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ase_athletics

# Secret for signing JWT access tokens (use a long random string; e.g. openssl rand -base64 32)
JWT_SECRET=change-me-in-development

# --- Optional ---
NODE_ENV=development
# NODE_ENV=production

# HTTP port (default 8000)
# PORT=8000

# Comma-separated extra browser origins allowed by CORS (localhost is included by default in code)
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
